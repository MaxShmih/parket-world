{%- liquid
  assign heading_size = block.settings.heading_size | default: 'h4'
  assign use_specs_setting = block.settings.use_specifications_metafield
  assign specs_mf = product.metafields.custom.specifications_text
  assign specs_raw = ''

  if specs_mf.value != blank
    assign specs_raw = specs_mf.value
  elsif specs_mf != blank
    assign specs_raw = specs_mf
  endif

  assign specs_raw = specs_raw | strip
  assign show_specs_table = false
  assign use_specs_metafield = false

  if use_specs_setting == true
    assign use_specs_metafield = true
  elsif use_specs_setting == false
    assign use_specs_metafield = false
  elsif block.settings.heading == 'Характеристики'
    assign use_specs_metafield = true
  endif

  if use_specs_metafield and specs_raw != blank
    assign show_specs_table = true
  endif
-%}
<details
  id="Details-{{ block.id }}-{{ section_id }}"
  class="accordion-details"
  is="accordion-group"
  {% if block.settings.default_open %}
    open
    aria-expanded="true"
  {% else %}
    aria-expanded="false"
  {% endif %}
>
  <summary class="accordion-details__summary flex items-center justify-between">
    <div class="flex items-center gap-2">
      {% render 'icons', icon: block.settings.icon %}
      <h2 class="{{ heading_size }} inline-richtext">
        {{ block.settings.heading | default: block.settings.page.title | escape }}
      </h2>
    </div>
    {%- render 'icon-plus-toggle' -%}
  </summary>
  <div class="accordion-details__content text-subtext{% unless show_specs_table %} rte{% endunless %}">
    {%- if show_specs_table -%}
      {% render 'product-specifications-table', specs_raw: specs_raw %}
    {%- else -%}
      {{ block.settings.content }}
      {{ block.settings.page.content }}
    {%- endif -%}
  </div>
</details>
