{%- comment -%}
  Таблиця характеристик з multiline metafield.
  Формат (кожен рядок): Назва|Значення
  Metafield: custom.specifications_text (multi-line text)
{%- endcomment -%}
{%- assign specs_raw = specs_raw | default: '' | strip -%}
{%- if specs_raw != blank -%}
  {%- liquid
    assign normalized = specs_raw | replace: '\r\n', '\n' | replace: '\r', '\n'
    assign rows = normalized | split: '\n'
  -%}
  <div class="product-specifications">
    <table class="product-specifications__table">
      <tbody>
        {%- for row in rows -%}
          {%- liquid
            assign row_stripped = row | strip
            if row_stripped == blank
              continue
            endif

            unless row_stripped contains '|'
              continue
            endunless

            assign parts = row_stripped | split: '|'
            assign label = parts[0] | strip
            assign value = parts[1] | strip
          -%}
          {%- if label != blank and value != blank -%}
            <tr>
              <th scope="row" class="product-specifications__label">{{ label }}</th>
              <td class="product-specifications__value">{{ value }}</td>
            </tr>
          {%- endif -%}
        {%- endfor -%}
      </tbody>
    </table>
  </div>
{%- endif -%}
